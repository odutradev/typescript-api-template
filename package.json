    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/marked": "^6.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
